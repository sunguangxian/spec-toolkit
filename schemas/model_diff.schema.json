{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/at-spec/model_diff.schema.json",
  "title": "AT Model Diff",
  "type": "object",
  "required": ["schema_version", "left", "right", "summary", "only_left", "only_right", "changed"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0", "1.1"] },
    "left": { "$ref": "#/$defs/modelSide" },
    "right": { "$ref": "#/$defs/modelSide" },
    "summary": {
      "type": "object",
      "required": ["only_left_count", "only_right_count", "changed_count"],
      "additionalProperties": false,
      "properties": {
        "only_left_count": { "type": "integer", "minimum": 0 },
        "only_right_count": { "type": "integer", "minimum": 0 },
        "changed_count": { "type": "integer", "minimum": 0 }
      }
    },
    "only_left": { "type": "array", "items": { "$ref": "#/$defs/commandRef" } },
    "only_right": { "type": "array", "items": { "$ref": "#/$defs/commandRef" } },
    "changed": { "type": "array", "items": { "$ref": "#/$defs/changedCommand" } }
  },
  "$defs": {
    "modelSide": {
      "type": "object",
      "required": ["model_id", "model_name", "version", "command_count"],
      "additionalProperties": false,
      "properties": {
        "model_id": { "type": "string" },
        "model_name": { "type": "string" },
        "version": { "type": "string" },
        "command_count": { "type": "integer", "minimum": 0 }
      }
    },
    "commandRef": {
      "type": "object",
      "required": ["id", "numeric_id", "display_id", "category", "source"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "numeric_id": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "display_id": { "type": "string" },
        "category": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "variantMeta": {
      "type": "object",
      "required": ["source", "reason"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "fieldChange": {
      "type": "object",
      "required": ["field", "left_value", "right_value"],
      "additionalProperties": true,
      "properties": {
        "field": { "type": "string" },
        "left_value": {},
        "right_value": {},
        "left_variant": { "$ref": "#/$defs/variantMeta" },
        "right_variant": { "$ref": "#/$defs/variantMeta" }
      }
    },
    "changedCommand": {
      "type": "object",
      "required": ["id", "numeric_id", "display_id", "category", "source", "changes"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "numeric_id": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "display_id": { "type": "string" },
        "category": { "type": "string" },
        "source": { "type": "string" },
        "changes": { "type": "array", "items": { "$ref": "#/$defs/fieldChange" } }
      }
    }
  }
}
